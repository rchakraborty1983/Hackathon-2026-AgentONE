{
  "servers": {
    "mcp-atlassian": {
      "url": "https://mcp.atlassian.com/v1/sse",
      "type": "sse"
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_TOKEN}"
      }
    },
    "tfs-jira-github": {
      "type": "stdio",
      "command": "${CLONE_DIR}\\.venv\\Scripts\\python.exe",
      "args": ["${CLONE_DIR}\\TFS_MCP_Server.py"]
    }
  },
  "inputs": []
}
